  "keyFeatures": [
    "One-liner WinGet app installation and update automation for Windows 10/11",
    "Scheduled automatic app updates with rollback script generation and toast notifications",
    "Active Directory user/computer management with ADWS-based querying",
    "Remote date and region format standardization across Windows servers",
    "Network diagnostics, printer management, and Windows Update utilities",
    "ClickUp task export to Markdown, HTML, or CSV with optional AI summaries via Gemini",
    "FlaUI-based PowerShell GUI automation testing with optional Proxmox VM isolation",
    "Cross-platform Git configuration with curated aliases and interactive TUI browser",
    "1Password credential integration across all tools",
    "Pester-tested scripts with 100% pass rates for core modules"
  ],
